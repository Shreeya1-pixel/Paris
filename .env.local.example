# Openworld Paris — Environment Variables
# Copy this file to .env.local and fill in your values

# ── Supabase ─────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role — server-only; for `npm run seed:paris` (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Mapbox (required for the map) ───────────────────────
# Public token from https://account.mapbox.com/access-tokens/
# Restrict by URL in the Mapbox dashboard for production.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token

# ── AI Chat (pick ONE — Groq is free and fastest) ────────



