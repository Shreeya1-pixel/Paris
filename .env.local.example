# Openworld Paris — Environment Variables
# Copy this file to .env.local and fill in your values

# ── Supabase ─────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role — server-only; for `npm run seed:paris` (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Mapbox (required for the map) ───────────────────────
# Public token from https://account.mapbox.com/access-tokens/
# Restrict by URL in the Mapbox dashboard for production.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token

# ── Foursquare Places API (optional — live nearby places) ─
# Sign up at https://location.foursquare.com/developer/
# Create a project → copy the API Key (starts with fsq3...)
# Without this key, the map still works using the curated local KB.
FOURSQUARE_API_KEY=fsq3your_foursquare_api_key

# ── Gemini AI (optional — powers chat + recommendations) ──
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
